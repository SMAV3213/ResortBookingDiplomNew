# Database Configuration
DB_PASSWORD=YourStrongPassword123!

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-min-32-characters-long!
JWT_ISSUER=ResortBookingApp
JWT_AUDIENCE=ResortBookingUsers
JWT_EXPIRATION_MINUTES=60

# API Configuration
ASPNETCORE_ENVIRONMENT=Production

# HTTPS Certificate Path (for production)
# ASPNETCORE_Kestrel__Certificates__Default__Path=/app/certificates/cert.pfx
# ASPNETCORE_Kestrel__Certificates__Default__Password=your-cert-password
